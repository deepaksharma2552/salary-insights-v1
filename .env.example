# ─────────────────────────────────────────────────────────────────────────────
# Salary Insights Portal — Environment Variables
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=salary_insights_db
POSTGRES_USER=salaryuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_a_strong_random_base64_secret_here

# ── OAuth2 — Google ───────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://yourdomain.com/api/oauth2/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OAuth2 — Facebook ─────────────────────────────────────────────────────────
# Console: https://developers.facebook.com/apps/
# Valid OAuth redirect URIs: https://yourdomain.com/api/oauth2/callback/facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ── OAuth2 — LinkedIn ─────────────────────────────────────────────────────────
# Console: https://www.linkedin.com/developers/apps
# Authorized redirect URLs: https://yourdomain.com/api/oauth2/callback/linkedin
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
# Your public domain (used for OAuth2 redirect URIs in backend)
FRONTEND_URL=https://yourdomain.com
